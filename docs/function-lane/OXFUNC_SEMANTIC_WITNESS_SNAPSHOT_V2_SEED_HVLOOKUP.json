      "category": "Lookup and reference functions",
      "metadata_status": "function_meta_curated",
      "signature_display": "HLOOKUP(lookup_value, table_array, row_index_num, [range_lookup])",
      "arg_specs": [
        {
          "arg_index": 1,
          "arg_name": "lookup_value",
          "arg_required": true,
          "arg_type_hint": "scalar",
          "arg_behavior_note": "Supports exact and approximate lookup, including the current-baseline wildcard text lane."
        },
        {
          "arg_index": 2,
          "arg_name": "table_array",
          "arg_required": true,
          "arg_type_hint": "reference_or_array",
          "arg_behavior_note": "Reference and array structure stays visible through the adapter seam."
        },
        {
          "arg_index": 3,
          "arg_name": "row_index_num",
          "arg_required": true,
          "arg_type_hint": "number",
          "arg_behavior_note": "Truncates toward zero before validation."
        },
        {
          "arg_index": 4,
          "arg_name": "range_lookup",
          "arg_required": false,
          "arg_type_hint": "logical",
          "arg_behavior_note": "Omitted means approximate-match mode."
        }
      ],
      "help_summary": "Looks for a value in the first row of a table and returns a value from a specified row.",
      "help_detail": "Current-baseline OxFunc support covers exact and approximate numeric lookup, wildcard text lookup on the exact lane, logical lookup values, and row-index validation.",
      "semantic_modes": [
        "exact_match",
        "approximate_match_sorted",
        "wildcard_text_lookup",
        "row_index_validation"
      ],
      "witness_examples": [
        {
          "example_id": "W68-HLOOKUP-001",
          "summary": "Exact numeric HLOOKUP baseline.",
          "outcome_note": "Returns 20 for HLOOKUP(2,{1,2,3;10,20,30},2,FALSE).",
          "evidence_ref_hint": "W68-LOOKUP-LOGICAL-RESIDUALS-BL-20260401"
        },
        {
          "example_id": "W68-HLOOKUP-002",
          "summary": "Approximate HLOOKUP defaults when range_lookup is omitted.",
          "outcome_note": "Returns 20 for HLOOKUP(2.9,{1,2,3;10,20,30},2).",
          "evidence_ref_hint": "W68-LOOKUP-LOGICAL-RESIDUALS-BL-20260401"
        },
        {
          "example_id": "W68-HLOOKUP-003",
          "summary": "Exact HLOOKUP supports the current-baseline wildcard lane.",
          "outcome_note": "Returns 20 for HLOOKUP(\"b*\",{\"abc\",\"bcd\";10,20},2,FALSE).",
          "evidence_ref_hint": "W68-LOOKUP-LOGICAL-RESIDUALS-BL-20260401"
        },
